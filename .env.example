# Copy this file to .env and fill in your values


# --- Weather (fallback) ---
# Free API key from https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# --- Plant information ---
# Free API key from https://perenual.com/docs/api
PERENUAL_API_KEY=

# --- Email alerts (Gmail) ---

EMAIL_SENDER=
EMAIL_APP_PASSWORD=
EMAIL_RECIPIENT=

# --- Tallinn coordinates  ---
TALLINN_LAT=59.437
TALLINN_LON=24.753

# --- Flask secret key (change to any random string) ---
SECRET_KEY=change-me-to-something-random
